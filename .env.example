# Server Configuration
PORT=3000
NODE_ENV=development

# Mercado Libre OAuth Configuration
ML_CLIENT_ID=your_client_id_here
ML_CLIENT_SECRET=your_client_secret_here
ML_REDIRECT_URI=http://localhost:3000/auth/callback
ML_SITE_ID=MLB

# Mercado Libre API URLs
ML_AUTH_URL=https://auth.mercadolibre.com/authorization
ML_TOKEN_URL=https://api.mercadolibre.com/oauth/token
ML_API_BASE=https://api.mercadolibre.com

# Session Configuration
SESSION_SECRET=your_super_secret_session_key_change_this

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10
